# Resend API key — obtener en https://resend.com/api-keys
# El endpoint /api/contact lee esta variable vía import.meta.env.RESEND_API_KEY
RESEND_API_KEY=

# Last.fm (widget de música). API key gratis: https://www.last.fm/api/account/create
# LASTFM_USER = tu nombre de usuario de Last.fm. Necesita scrobbling de Spotify activo.
LASTFM_API_KEY=
LASTFM_USER=
