---
import "../styles/variables.css";
import "../styles/fonts.css";
import "../styles/base.css";
import "../styles/cursors.css";
import "../styles/utilities.css";
import "../styles/components-global.css";
import Tools from "../components/Tools.astro";
import { ClientRouter } from "astro:transitions";
import { tFor, getAlternatePath, type Locale } from "../i18n";


interface Props {
  title: string;
}

const { title } = Astro.props;
const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'es';
const t = tFor(Astro);
const currentPath = Astro.url.pathname;
const altPathEs = getAlternatePath(currentPath, 'es');
const altPathEn = getAlternatePath(currentPath, 'en');
const siteOrigin = Astro.site?.origin ?? 'https://vindevsito.dev';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <!-- easter egg histórico (binario "I am god"): 01001001 00100000 01100001 01101101 00100000 01100111 01101111 01100100 -->
    <meta name="description" content={t('layout.meta.description')} />
    <meta name="viewport" content="width=device-width" />
    <link id="icon" rel="icon" type="image/svg+xml" href="/circle.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="alternate" hreflang="es" href={siteOrigin + altPathEs} />
    <link rel="alternate" hreflang="en" href={siteOrigin + altPathEn} />
    <link rel="alternate" hreflang="x-default" href={siteOrigin + altPathEs} />

    <title>{title}</title>

    <script is:inline>
      (function () {
        const STORAGE_KEY = 'portfolio-locale';
        const path = window.location.pathname;
        const onEn = path.startsWith('/en/') || path === '/en';
        const current = onEn ? 'en' : 'es';

        let target;
        const stored = localStorage.getItem(STORAGE_KEY);
        if (stored === 'es' || stored === 'en') {
          target = stored;
        } else {
          const lang = (navigator.language || 'en').toLowerCase();
          // EN default for any non-ES browser language (more inclusive internationally)
          target = lang.startsWith('es') ? 'es' : 'en';
          try { localStorage.setItem(STORAGE_KEY, target); } catch (e) { /* private mode */ }
        }

        if (target === current) {
          // Sync localStorage if user navigated manually past auto-detect
          if (stored !== current) {
            try { localStorage.setItem(STORAGE_KEY, current); } catch (e) { /* ignore */ }
          }
          return;
        }

        let newPath;
        if (target === 'en') {
          newPath = '/en' + (path === '/' ? '' : path);
        } else {
          newPath = path.replace(/^\/en(\/|$)/, '/');
          if (newPath === '') newPath = '/';
        }
        window.location.replace(newPath + window.location.search + window.location.hash);
      })();
    </script>

    <ClientRouter />
  </head>
  <body class="noise flex j_sb">
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <filter id="glassRefract" x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="fractalNoise" baseFrequency="0.012 0.018" numOctaves="2" seed="7" result="noise"/>
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="22" xChannelSelector="R" yChannelSelector="G" />
        </filter>
        <!-- Hexagon fisheye: two linear gradient displacement maps (R horizontal,
             G vertical) blended via screen → mid-gray center = no shift, edges
             push outward = subtle radial bulge. Activated only on hover. -->
        <!-- <filter id="hexFisheye" x="-40%" y="-40%" width="180%" height="180%">
          <feImage
            width="100%"
            height="100%"
            preserveAspectRatio="none"
            href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100' preserveAspectRatio='none'><linearGradient id='x' x1='0' x2='1'><stop offset='0' stop-color='%23000'/><stop offset='1' stop-color='%23f00'/></linearGradient><rect width='100' height='100' fill='url(%23x)'/></svg>"
            result="xMap"
          />
          <feImage
            width="100%"
            height="100%"
            preserveAspectRatio="none"
            href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100' preserveAspectRatio='none'><linearGradient id='y' x1='0' x2='0' y1='0' y2='1'><stop offset='0' stop-color='%23000'/><stop offset='1' stop-color='%2300ff00'/></linearGradient><rect width='100' height='100' fill='url(%23y)'/></svg>"
            result="yMap"
          />
          <feBlend in="xMap" in2="yMap" mode="screen" result="dispmap" />
          <feDisplacementMap in="SourceGraphic" in2="dispmap" scale="10" xChannelSelector="R" yChannelSelector="G" />
        </filter> -->
      </defs>
    </svg>
    <!-- <CustomCursor data-astro-transition="swap" /> -->
    <div id="dot-container" class="fixed" transition:persist></div>
    <!-- Capa de fondo WebGL (progressive enhancement): ruido + dots + gemas.
         Oculta por defecto; el controlador la activa (html.gl-active) sólo si hay
         WebGL y el rendimiento es bueno. Fallback = CSS actual (.noise + dots.ts). -->
    <canvas id="bg-gl" transition:persist aria-hidden="true"></canvas>
    <audio
      id="audio-player"
      transition:persist
      src="/VIN.ogg"
      autoplay
      loop
      preload="auto"></audio>
    <slot name="navbar" data-astro-transition="swap" />
    <Tools transition:persist />
    <section id="side-container" class="relative flex" transition:persist>
      <slot name="sidebar" data-astro-transition="persist" />
    </section>
    <section id="content-container" class="relative flex_col">
      <main class="flex_col view-transition">
        <slot name="main" data-astro-transition="swap" />
      </main>
      <slot
        name="footer"
        data-astro-transition="persist"
        transition:animate="fade"
      />
    </section>
  </body>
</html>
<script>
  const activeIcon: string = "/circle.svg";
  const inactiveIcon: string = "/cross.svg";

  function changeFavicon(iconURL: string): void {
    const favicon = document.getElementById("icon") as HTMLLinkElement;
    if (favicon) {
      favicon.href = iconURL;
    }
  }

  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "visible") {
      changeFavicon(activeIcon);
    } else {
      changeFavicon(inactiveIcon);
    }
  });

  let deviceWidth = window.innerWidth;
  document.body.style.width = `${deviceWidth}px`;
  window.addEventListener("resize", () => {
    deviceWidth = window.innerWidth;
    document.body.style.width = `${deviceWidth}px`;
  });

  document.addEventListener("astro:page-load", () => {
    const sidebarRef = document.querySelector(
      "#side-container"
    ) as HTMLElement;
    const updateSidebarSize = () => {
      const aside = sidebarRef?.querySelector("aside");
      if (!aside) return;
      const { width, height } = aside.getBoundingClientRect();
      sidebarRef.style.width = `${width}px`;
      sidebarRef.style.height = `${height}px`;
    };

    const mediaQuery = window.matchMedia("(max-width: 1075px)");

    const handleMediaChange = (event: MediaQueryListEvent) => {
      if (event.matches) {
        sidebarRef.style.display = "none";
      } else {
        sidebarRef.style.display = "flex";
        updateSidebarSize();
      }
    };

    mediaQuery.addEventListener("change", handleMediaChange);
    handleMediaChange({ matches: mediaQuery.matches } as MediaQueryListEvent);

    const audioPlayer = document.querySelector("#audio-player") as HTMLAudioElement;

    audioPlayer.addEventListener("ended", function () {
      this.currentTime = 0;
      this.play();
    });

    const tryPlayAudio = () => {
      
      if ((window as any).audioController) {
        (window as any).audioController.playWithMuteState();
      } else {
        
        const savedMutedState = sessionStorage.getItem('audioMuted');
        const shouldBeMuted = savedMutedState === 'true';
        
        audioPlayer.muted = shouldBeMuted;
        audioPlayer.play().catch((error) => {
          console.log("Reproducción bloqueada:", error);
        });
      }
    };

    const enableAudioOnInteraction = () => {
      const events = [
        "click",
        "dblclick",
        "mousemove",
        "mouseup",
        "mousedown",
        "scroll",
        "keydown",
        "keyup",
        "keypress",
        "touchstart",
        "touchend",
        "visibilitychange",
        "focus",
        "blur",
        "pointerdown",
        "pointerup",
        "contextmenu",
        "dragstart",
        "dragend",
      ];

      events.forEach((event) => {
        document.addEventListener(
          event,
          () => {
            tryPlayAudio();
          },
          { once: true }
        );
      });
    };

    enableAudioOnInteraction();
    
    
    (window as any).audioController = {
      getAudioPlayer: () => audioPlayer,
      
      
      playWithMuteState: () => {
        const savedMutedState = sessionStorage.getItem('audioMuted');
        const shouldBeMuted = savedMutedState === 'true';
        
        audioPlayer.muted = shouldBeMuted;
        audioPlayer.play().catch((error) => {
          if (error.name !== 'NotAllowedError') {
            console.log("Error de reproducción:", error);
          }
        });
      },
      
      
      isMuted: () => {
        const savedMutedState = sessionStorage.getItem('audioMuted');
        return savedMutedState === 'true';
      },
      
      
      setMuted: (muted: boolean) => {
        audioPlayer.muted = muted;
        sessionStorage.setItem('audioMuted', muted.toString());
      }
    };
    
    
    const safePlay = () => {
      (window as any).audioController.playWithMuteState();
    };
    
    setTimeout(safePlay, 1000);
  });
</script>
<script src="/src/components/dots.ts"></script>

<!-- Controlador del fondo WebGL (progressive enhancement) -->
<script>
  import { initGemGL } from "../utils/gemGL";

  let destroyGL: (() => void) | null = null;

  function hasWebGL(): boolean {
    try {
      const c = document.createElement("canvas");
      return !!(c.getContext("webgl") || c.getContext("experimental-webgl"));
    } catch { return false; }
  }

  // Flag manual (botón de Tools gated por env PUBLIC_PERF_TOGGLE): fuerza el
  // fallback CSS liviano aunque haya WebGL.
  function forcedLowPerf(): boolean {
    try { return localStorage.getItem("forceLowPerf") === "1"; } catch { return false; }
  }

  function setupBgGL() {
    const canvas = document.getElementById("bg-gl") as HTMLCanvasElement | null;
    if (!canvas) return;
    if (destroyGL) { destroyGL(); destroyGL = null; }

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce || !hasWebGL() || forcedLowPerf()) {
      document.documentElement.classList.remove("gl-active"); // fallback CSS
      return;
    }
    const techEls = Array.from(
      document.querySelectorAll<HTMLElement>(".techs_container li:not(.li_hidden)")
    );
    document.documentElement.classList.add("gl-active");
    destroyGL = initGemGL(canvas, {
      fullViewport: true,
      perInstanceLogo: true,
      layoutEls: techEls,
      onLowPerf: () => {
        // FPS pésimo → bajar a los elementos livianos (CSS) en vivo.
        if (destroyGL) { destroyGL(); destroyGL = null; }
        document.documentElement.classList.remove("gl-active");
      },
    });
  }

  document.addEventListener("astro:page-load", setupBgGL);
  // El botón de Tools cambió 'forceLowPerf' → re-evaluar (apaga o re-monta GL).
  document.addEventListener("perf:toggle", setupBgGL);
  document.addEventListener("astro:before-swap", () => {
    if (destroyGL) { destroyGL(); destroyGL = null; }
  });
</script>

<style is:global>
  /* Capa de fondo WebGL: fija a viewport, detrás del contenido. Oculta hasta
     que el controlador la active (html.gl-active). */
  #bg-gl {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: none;
  }
  html.gl-active #bg-gl { display: block; }
  /* Con el canvas activo, el fondo lo dibuja WebGL → ocultar ruido CSS + dots
     + el visual del hex (conservando los <li> para layout/posiciones/a11y). */
  html.gl-active body.noise { background: #000; }
  html.gl-active #dot-container { display: none; }
  html.gl-active .techs_container li { opacity: 0; }
</style>
<style>
  #dot-container {
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
  }

  #side-container {
    z-index: 20;
    margin: 5px;
    flex-shrink: 0;
  }

  #content-container {
    z-index: 10;
    flex-grow: 2;
  }

  main {
    gap: 5rem;
    align-self: center;
  }

  @media screen and (min-width: 1440px) {
    main {
      width: 1200px;
    }
  }

  @media screen and (max-width: 425px) {
    main {
      margin-inline:1rem;
    }
  }
</style>
