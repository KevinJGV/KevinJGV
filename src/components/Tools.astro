---
import { tFor } from "../i18n";
const t = tFor(Astro);
// Gate build-time: el botón de bajo rendimiento sólo se renderiza si existe la
// env PUBLIC_PERF_TOGGLE (cualquier valor truthy). Sin la env, no hay botón.
const showPerfToggle = !!import.meta.env.PUBLIC_PERF_TOGGLE;
---

<aside id="tools" class="flex fixed j_sa glass1">
  <section class="tool" id="audio-control">
    <button id="mute-button" aria-label={t('tools.muteAria')}>
      <svg id="volume-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
      </svg>
    </button>
  </section>
  <section class="tool" id="locale-control">
    <button id="locale-toggle" aria-label={t('tools.localeToggleAria')}>
      <span class="locale-label">{(Astro.currentLocale === 'en' ? 'en' : 'es').toUpperCase()}</span>
    </button>
  </section>
  {showPerfToggle && (
    <section class="tool" id="perf-control">
      <button id="perf-toggle" aria-label={t('tools.perfToggleAria')} aria-pressed="false" title="Bajo rendimiento (CSS)">
        <svg id="perf-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/>
        </svg>
      </button>
    </section>
  )}
</aside>

<style>
  #tools {
    width: fit-content;
    top: 15px;
    right: 15px;
    height: 50px;
    z-index: 99;
    border-radius: 115px;
    padding-inline: 15px;
    transform-origin: top right;
    animation: tools-grow-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes tools-grow-in {
    from {
      opacity: 0;
      transform: scale(0.85);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Audio control hidden until first interaction (browser autoplay policy);
     locale-control and rest of toolbar always visible from initial load.
     Uses max-width + opacity (NOT display:none) so the toolbar grows
     smoothly when audio button appears — no layout hole, no snap. */
  #audio-control {
    opacity: 0;
    max-width: 0;
    overflow: hidden;
    pointer-events: none;
    transition:
      opacity 0.4s ease,
      max-width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #audio-control.visible {
    opacity: 1;
    max-width: 50px;
    pointer-events: auto;
  }

  .tool {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    color: white;
    font-weight: bold;
    font-size: small;
  }

  .tool > p {
    --var: -0%;
    position: absolute;
    top: var(--var);
    transition: all 0.7s;
    background-color: dodgerblue;
    border-radius: 7px;
    opacity: 0;
    padding-inline: 7px;
    padding-block: 3px;
    width: max-content;
  }
  .tool > p::after {
    content: "";
    position: absolute;
    border-top: 10px solid dodgerblue;
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
    top: 100%;
    left: 50%;
    transform: translate(-50%);
  }
  .tool > a {
    --var: -0%;
    position: absolute;
    bottom: var(--var);
    width: max-content;
    transition: all 0.7s;
    opacity: 0;
    padding-inline: 7px;
    padding-block: 3px;
    background-color: crimson;
    border-radius: 7px;
  }
  .tool > a::after {
    content: "";
    position: absolute;
    border-bottom: 10px solid crimson;
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
    bottom: 100%;
    left: 50%;
    transform: translate(-50%);
  }

  .tool:hover > a,
  .tool:hover > p {
    --var: -65%;
    opacity: 1;
  }

  .tool:hover {
    z-index: 15;
  }

  #tools:hover > .tool:not(:hover) {
    filter: blur(3px);
    transform: scale(0.8);
  }

  #tools svg {
    height: 30px;
  }

  #audio-control button {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 5px;
    border-radius: 50%;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #audio-control button:hover {
    background-color: rgba(255, 255, 255, 0.1);
    transform: scale(1.1);
  }

  #audio-control.muted #volume-icon {
    opacity: 0.5;
  }

  #locale-control button {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 5px;
    font-family: "Poppins-S";
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  #locale-control button:hover {
    background-color: rgba(255, 255, 255, 0.1);
    transform: scale(1.1);
  }

  #perf-control button {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 5px;
    border-radius: 50%;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #perf-control button:hover {
    background-color: rgba(255, 255, 255, 0.1);
    transform: scale(1.1);
  }

  /* Estado activo = bajo rendimiento forzado (WebGL apagado) → ámbar */
  #perf-control button[aria-pressed="true"] {
    color: #ffb547;
  }

  #perf-control button:not([aria-pressed="true"]) #perf-icon {
    opacity: 0.5;
  }

</style>

<script>
  let audioControlInitialized = false;
  let audioControlVisible = false;

  function showAudioControlOnFirstInteraction() {
    if (audioControlVisible) return;

    const audioControlElement = document.getElementById('audio-control');
    if (audioControlElement) {
      audioControlElement.classList.add('visible');
      audioControlVisible = true;
      sessionStorage.setItem('audioControlVisible', 'true');
    }
  }

  function restoreAudioControlVisibility() {
    const savedVisibility = sessionStorage.getItem('audioControlVisible');
    if (savedVisibility === 'true') {
      const audioControlElement = document.getElementById('audio-control');
      if (audioControlElement) {
        audioControlElement.classList.add('visible');
        audioControlVisible = true;
      }
    }
  }

  function setupFirstInteractionDetection() {
    restoreAudioControlVisibility();

    if (audioControlVisible) return;
    
    const interactionEvents = [
      'click',
      'dblclick',
      'mousedown',
      'mouseup',
      'keydown',
      'keyup',
      'touchstart',
      'touchend',
      'pointerdown',
      'pointerup'
    ];
    
    const handleFirstInteraction = () => {
      showAudioControlOnFirstInteraction();
      
      interactionEvents.forEach(eventType => {
        document.removeEventListener(eventType, handleFirstInteraction);
      });
    };
    
    interactionEvents.forEach(eventType => {
      document.addEventListener(eventType, handleFirstInteraction, { once: true });
    });
  }
  
  function initAudioControl() {
    if (audioControlInitialized) {
      return;
    }
    
    const muteButton = document.getElementById('mute-button');
    const volumeIcon = document.getElementById('volume-icon');
    const audioControl = document.getElementById('audio-control');

    if (!muteButton || !volumeIcon || !audioControl) {
      return;
    }
    
    audioControlInitialized = true;
    
    function getAudioPlayer() {
      return document.querySelector('#audio-player') as HTMLAudioElement;
    }
    
    function updateAudioStatus(isMuted: boolean) {
      
      if (isMuted) {
        audioControl.classList.add('muted');
        volumeIcon.innerHTML = `
          <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
        `;
      } else {
        audioControl.classList.remove('muted');
        volumeIcon.innerHTML = `
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
        `;
      }
    }
    
    function toggleAudio() {
      const audioPlayer = getAudioPlayer();
      
      if (audioPlayer) {
        const newMutedState = !audioPlayer.muted;
        
        if ((window as any).audioController) {
          (window as any).audioController.setMuted(newMutedState);
        } else {
          audioPlayer.muted = newMutedState;
          sessionStorage.setItem('audioMuted', newMutedState.toString());
        }
        
        updateAudioStatus(newMutedState);
      } 
    }
    
    muteButton.addEventListener('click', toggleAudio);

    function setInitialAudioState() {
      const audioPlayer = getAudioPlayer();
      if (!audioPlayer) return false;
      
      const savedMutedState = sessionStorage.getItem('audioMuted');
      const shouldBeMuted = savedMutedState === 'true';
      
      if ((window as any).audioController) {
        (window as any).audioController.setMuted(shouldBeMuted);
      } else {
        audioPlayer.muted = shouldBeMuted;
      }
      
      updateAudioStatus(shouldBeMuted);
      
      return true;
    }
    
    let observer = null;
    function createAudioObserver() {
      const audioPlayer = getAudioPlayer();
      if (!audioPlayer) return;
      
      if (observer) {
        clearInterval(observer);
      }
      
      let lastMutedState = audioPlayer.muted;
      
      const checkAudioState = () => {
        if (audioPlayer.muted !== lastMutedState) {
          lastMutedState = audioPlayer.muted;
          updateAudioStatus(audioPlayer.muted);
        }
      };
      
      observer = setInterval(checkAudioState, 500);
      
      audioPlayer.addEventListener('volumechange', () => {
        updateAudioStatus(audioPlayer.muted);
        sessionStorage.setItem('audioMuted', audioPlayer.muted.toString());
      });
    }
    
    function initialize() {
      if (setInitialAudioState()) {
        createAudioObserver();
      } else {
        setTimeout(() => {
          if (setInitialAudioState()) {
            createAudioObserver();
          } else {
            setTimeout(() => {
              setInitialAudioState();
              createAudioObserver();
            }, 1000);
          }
        }, 500);
      }
    }
    
    initialize();
  }
  
  function cleanupAudioControl() {
    audioControlInitialized = false;
  }

  function initLocaleToggle() {
    const btn = document.getElementById('locale-toggle');
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';
    btn.addEventListener('click', () => {
      const path = window.location.pathname;
      const onEn = path.startsWith('/en/') || path === '/en';
      const target = onEn ? 'es' : 'en';
      try { localStorage.setItem('portfolio-locale', target); } catch (e) { /* ignore */ }
      let newPath: string;
      if (target === 'en') {
        newPath = '/en' + (path === '/' ? '' : path);
      } else {
        newPath = path.replace(/^\/en(\/|$)/, '/');
        if (newPath === '') newPath = '/';
      }
      window.location.assign(newPath);
    });
  }

  function updateLocaleLabel() {
    const label = document.querySelector('#locale-toggle .locale-label');
    if (!label) return;
    const onEn = window.location.pathname.startsWith('/en');
    label.textContent = onEn ? 'EN' : 'ES';
  }

  // Toggle de bajo rendimiento (sólo existe si la env PUBLIC_PERF_TOGGLE
  // renderizó el botón). Persiste 'forceLowPerf' en localStorage y avisa al
  // controlador del fondo WebGL (Layout) vía evento 'perf:toggle'.
  function readForceLowPerf(): boolean {
    try { return localStorage.getItem('forceLowPerf') === '1'; } catch (e) { return false; }
  }

  function initPerfToggle() {
    const btn = document.getElementById('perf-toggle');
    if (!btn) return; // no renderizado (sin env)

    const sync = () => {
      btn.setAttribute('aria-pressed', String(readForceLowPerf()));
    };

    if (btn.dataset.bound !== '1') {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const next = !readForceLowPerf();
        try { localStorage.setItem('forceLowPerf', next ? '1' : '0'); } catch (e) { /* ignore */ }
        document.dispatchEvent(new CustomEvent('perf:toggle'));
        sync();
      });
    }
    sync();
  }

  function initializeTools() {
    restoreAudioControlVisibility();
    setupFirstInteractionDetection();
    initAudioControl();
    initLocaleToggle();
    updateLocaleLabel();
    initPerfToggle();
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeTools);
  } else {
    initializeTools();
  }
  
  document.addEventListener('astro:page-load', initializeTools);
  document.addEventListener('astro:before-preparation', cleanupAudioControl);

  setTimeout(() => {
    restoreAudioControlVisibility();
  }, 100);
</script>
