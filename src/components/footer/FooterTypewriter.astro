---
import Anchor from "../Anchor.astro";
import FooterWheelSVG from "./FooterWheelSVG.astro";
import esStrings from "../../i18n/es";
import enStrings from "../../i18n/en";
import { dynamicColors } from "./typewriter-words";
import { tFor, getAlternatePath, type Locale } from "../../i18n";

const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'es';
const t = tFor(Astro);
const wordsEs = esStrings.footer.typewriterWords;
const wordsEn = enStrings.footer.typewriterWords;
const contactHref = getAlternatePath('/contact', locale);
---

<section id="top_foot" class="flex j_sb">
  <div>
    <h3 class="Dela">
      {t('footer.typewriterPrefix')}<span
        id="dinamic_text"
        data-words-es={JSON.stringify(wordsEs)}
        data-words-en={JSON.stringify(wordsEn)}
        data-colors={JSON.stringify(dynamicColors)}
      ></span><span id="console"> █ </span>
    </h3>
    <Anchor
      href={contactHref}
      text={t('footer.contactCta')}
      max_font_size="2rem"
      min_font_size="2rem"
      bgHeight="2.2rem"
      svgh={21}
      svgw={20}
      svg={true}
    />
  </div>
  <div>
    <FooterWheelSVG />
  </div>
</section>

<script>
  // View transitions re-fire astro:page-load; without cleanup the prior
  // setInterval keeps writing to a (possibly detached) element and the
  // typewriter visibly freezes after sidebar navigation.
  let typeIntervalId: number | null = null;
  let cursorIntervalId: number | null = null;

  function clearTypewriterIntervals() {
    if (typeIntervalId !== null) {
      window.clearInterval(typeIntervalId);
      typeIntervalId = null;
    }
    if (cursorIntervalId !== null) {
      window.clearInterval(cursorIntervalId);
      cursorIntervalId = null;
    }
  }

  function nextOrder(source: string[], avoidFirst: string | null): string[] {
    const arr = source.slice();
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    if (avoidFirst !== null && arr.length > 1 && arr[0] === avoidFirst) {
      const j = 1 + Math.floor(Math.random() * (arr.length - 1));
      [arr[0], arr[j]] = [arr[j], arr[0]];
    }
    return arr;
  }

  function consoleText(source: string[], id: string, colors: string[]) {
    clearTypewriterIntervals();
    if (colors === undefined) colors = ["#fff"];
    let visible = true;
    const con = document.querySelector<HTMLElement>("#console");
    let letterCount = 1;
    let x = 1;
    let waiting = false;
    const target = document.querySelector<HTMLElement>(id);
    if (!target || !con) return;
    if (source.length === 0) return;
    // Cycle through the full set before repeating; on refill the next first
    // word can't equal the last word from the previous cycle.
    let lastShown: string | null = null;
    let words: string[] = nextOrder(source, lastShown);
    target.setAttribute(
      "style",
      "color:" + colors[Math.floor(Math.random() * colors.length)]
    );
    typeIntervalId = window.setInterval(function () {
      if (letterCount === 0 && waiting === false) {
        waiting = true;
        target.innerHTML = words[0].substring(0, letterCount);
        window.setTimeout(function () {
          const usedColor = colors.shift()!;
          colors.push(usedColor);
          const finishedWord = words.shift()!;
          lastShown = finishedWord;
          if (words.length === 0) {
            words = nextOrder(source, lastShown);
          }
          x = 1;
          target.setAttribute(
            "style",
            "color:" + colors[Math.floor(Math.random() * colors.length)]
          );
          letterCount += x;
          waiting = false;
        }, 1000);
      } else if (letterCount === words[0].length + 1 && waiting === false) {
        waiting = true;
        window.setTimeout(function () {
          x = -1;
          letterCount += x;
          waiting = false;
        }, 1000);
      } else if (waiting === false) {
        target.innerHTML = words[0].substring(0, letterCount);
        letterCount += x;
      }
    }, 120);
    cursorIntervalId = window.setInterval(function () {
      if (visible === true) {
        con.id = "console";
        con.className = "hidden";
        visible = false;
      } else {
        con.id = "console";
        con.className = "";
        visible = true;
      }
    }, 400);
  }

  function initTypewriter() {
    const target = document.querySelector<HTMLElement>("#dinamic_text");
    if (!target) {
      clearTypewriterIntervals();
      return;
    }
    const onEn = window.location.pathname.startsWith('/en');
    const wordsRaw = onEn ? target.dataset.wordsEn : target.dataset.wordsEs;
    const colorsRaw = target.dataset.colors;
    let words: string[] = [];
    let colors: string[] = [];
    try { words = wordsRaw ? JSON.parse(wordsRaw) : []; } catch { words = []; }
    try { colors = colorsRaw ? JSON.parse(colorsRaw) : []; } catch { colors = []; }
    if (words.length === 0) {
      clearTypewriterIntervals();
      return;
    }
    consoleText([...words], "#dinamic_text", [...colors]);
  }

  document.addEventListener("astro:page-load", initTypewriter);
  document.addEventListener("astro:before-swap", clearTypewriterIntervals);
</script>

<style>
  #top_foot {
    align-items: center;
    margin-inline: 50px;
    margin-block: 130px;
    height: fit-content;
    gap: 3rem;
  }

  #top_foot h3 {
    font-size: clamp(2.5rem, 1.0774rem + 3.7936vw, 5rem);
    margin-bottom: 30px;
  }

  #console {
    display: inline-block;
    position: relative;
    left: 10px;
  }

  @media screen and (max-width: 1075px) {
    #top_foot {
      flex-direction: column;
      align-items: start;
    }

    #top_foot div:last-child {
      align-self: center;
      margin-block: 1rem;
    }

    #dinamic_text::before {
      content: "";
      display: block;
    }
  }

  @media screen and (max-width: 425px) {
    #top_foot {
      margin-inline: 1rem;
    }
  }
</style>
