---
import TextHighlighted from "../Highlighter.astro";
import { tFor, getAlternatePath, type Locale } from "../../i18n";
const t = tFor(Astro);
const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'es';
const contactHref = getAlternatePath('/contact', locale);
---

<article id="home1" class="home_article flex relative">
  <section id="home1_text" class="flex_col j_se">
    <div id="home1_top" class="flex_col j_c">
      <span class="Dela">{t('home.hero.greeting')}</span>
      <h1 class="Dela">{t('home.hero.heading')}</h1>
      <i>
        <span class="Ansterdam">{t('home.hero.subtitle')}</span>
        <span class="Poppins-R">&</span>
        <TextHighlighted
          text="Empanada Lover"
          el="span"
          font_size="2rem"
          bg_Color="#6c8c65"
        />
      </i>
      <p class="Poppins-S">
        {t('home.hero.status')}<br /><a href={contactHref}>{t('home.hero.statusCta')}</a>
      </p>
    </div>
    <div id="home1_bot" class="Poppins-R">
      <p set:html={t('home.hero.body')} />
    </div>
  </section>
  <section id="home1_img" class="sticky">
    <img
      id="photo"
      src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
      alt="Kevin"
      class="unselected relative"
      draggable="false"
      decoding="async"
    />
  </section>
</article>

<style>
  #home1 {
    gap: 20rem;
  }

  #home1_text {
    gap: 200px;
  }

  #home1_top {
    height: 100vh;
    padding-top: 200px;
  }

  #home1_top span {
    font-size: clamp(4rem, 1.0774rem + 3.7936vw, 5rem);
    line-height: 0.9;
  }

  #home1_top h1 {
    font-size: clamp(5rem, 1.0774rem + 3.7936vw, 7rem);
    margin: 0;
  }

  #home1_top i {
    font-size: clamp(1.5rem, 0.0774rem + 1.7936vw, 2rem);
    margin-bottom: 3rem;
  }

  #home1_top i span {
    font-size: clamp(2rem, 0.0774rem + 1.7936vw, 3rem);
  }

  #home1_top a {
    text-decoration: underline;
  }

  #home1_img {
    top: 150px;
    width: 0;
    height: fit-content;
  }

  #home1_bot p {
    font-size: clamp(1rem, 0.0774rem + 1.7936vw, 1.5rem);
  }

  #photo {
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%);
    width: 450px;
    opacity: 0;
    transition: opacity 0.45s ease;
  }
  #photo.ready {
    opacity: 1;
  }

  @media screen and (max-width: 780px) {
    #home1_top i {
      padding-top: 2rem;
    }

    #home1_bot p {
      transform: unset;
    }

    #home1_img {
      position: absolute;
      width: 0;
      top: 695px;
      right: 50%;
      opacity: 0.4;
      transform: scale(0.5);
      z-index: -1;
    }

    #photo {
      width: 315px;
    }
  }

  @media screen and (max-width: 460px) {
    .Ansterdam {
      font-family: "Times New Roman", Times, serif;
    }
  }
</style>

<script>
  import { heroPhotos } from "../../data/heroPhotos";

  // Elige una foto al azar en cada carga/navegación (como el reshuffle de techs)
  // y la revela con fade al cargar. El <img> arranca con un placeholder
  // transparente (sin red) → un solo fetch real, sin doble carga ni flash.
  function setHeroPhoto() {
    const img = document.getElementById("photo") as HTMLImageElement | null;
    if (!img || heroPhotos.length === 0) return;
    const url = heroPhotos[Math.floor(Math.random() * heroPhotos.length)].src;
    img.classList.remove("ready");
    const reveal = () => img.classList.add("ready");
    img.addEventListener("load", reveal, { once: true });
    img.src = url;
    if (img.complete && img.naturalWidth > 0) reveal(); // cacheada
  }

  document.addEventListener("astro:page-load", setHeroPhoto);
</script>
