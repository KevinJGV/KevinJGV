---
import Hexagon from "../Hexagon.astro";
import Anchor from "../Anchor.astro";
import { technologies, type Technology } from "../../data/technologies";
import { computeLockedCount, generateLayout, shuffleInPlace } from "../../utils/hexLayout";
import { tFor, getAlternatePath, type Locale } from "../../i18n";
const t = tFor(Astro);
const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'es';
const meHref = getAlternatePath('/me', locale);

// Initial server-rendered layout. Client-side reshuffles on astro:page-load
// (see <script> at bottom). Server layout still respects the constraints so
// the no-JS path renders a valid honeycomb.
const lockedCount = computeLockedCount(technologies.length);
const initialLayout = generateLayout(technologies.length, lockedCount);
const initialTechOrder: Technology[] = technologies.slice();
shuffleInPlace(initialTechOrder);

type RenderSlot = Technology | null;
let _idx = 0;
const initialSlots: RenderSlot[] = (initialLayout ?? []).map((isLocked) =>
  isLocked ? null : initialTechOrder[_idx++]
);
// Fallback if constraints couldn't be met: render techs sequentially with no locked.
if (initialSlots.length === 0) {
  for (const t of initialTechOrder) initialSlots.push(t);
}

const s = "120px";
const r = 1;
const mv = "5px";
---

<section id="techs">
  <h2 class="Dela">
    <span class="hidden_text">{t('home.techs.titleHover')}</span> {t('home.techs.title')}
  </h2>
  <div class="techs_container grid unselected">
    <ul>
      {initialSlots.map((slot) =>
        slot ? <Hexagon src={slot.src} title={slot.title} href={slot.href} /> : <Hexagon />
      )}
    </ul>
  </div>
</section>

<blockquote class="text_center">
  <Anchor
    href={meHref}
    text={t('home.techs.aboutMeAnchor')}
    max_font_size="7rem"
    min_font_size="2rem"
    bgHeight="7.5rem"
    svgh={76}
    svgw={75}
    svg={true}
    responsive={true}
  />
</blockquote>

<script>
  import { generateLayout, shuffleInPlace } from "../../utils/hexLayout";

  function reshuffleHexagons() {
    const ul = document.querySelector<HTMLUListElement>(".techs_container ul");
    if (!ul) return;
    const lis = Array.from(ul.children) as HTMLLIElement[];
    // Tech vs locked partitioning: locked hexagons have class `li_hidden`
    // (set by Hexagon.astro when no `src` is provided).
    const lockedLis = lis.filter((li) => li.classList.contains("li_hidden"));
    const techLis = lis.filter((li) => !li.classList.contains("li_hidden"));
    if (techLis.length === 0) return;
    const layout = generateLayout(techLis.length, lockedLis.length);
    if (!layout) return;
    shuffleInPlace(techLis);
    let ti = 0,
      li = 0;
    for (const isLocked of layout) {
      if (isLocked) {
        if (li < lockedLis.length) ul.appendChild(lockedLis[li++]);
      } else {
        if (ti < techLis.length) ul.appendChild(techLis[ti++]);
      }
    }
  }

  function bindPointerMove() {
    const techsList = document.querySelector(".techs_container ul");
    if (!techsList || (techsList as HTMLElement).dataset.bound === "1") return;
    (techsList as HTMLElement).dataset.bound = "1";
    techsList.addEventListener("pointermove", (ev) => {
      const target = (ev.target as HTMLElement).closest("li");
      if (target) {
        const rect = target.getBoundingClientRect();
        const mouseEv = ev as PointerEvent;
        const rx = ((mouseEv.clientX - rect.left) / rect.width) * 100;
        const ry = ((mouseEv.clientY - rect.top) / rect.height) * 100;
        target.style.setProperty("--x", `${rx}%`);
        target.style.setProperty("--y", `${ry}%`);
      }
    });
  }

  // Navegación: el hexágono (<li data-href>) abre el sitio de su tecnología en
  // nueva pestaña. Delegado en el <ul> → sobrevive al reshuffle. Soporta teclado
  // (Enter/Espacio) porque los <li> navegables son role="link" tabindex="0".
  function bindNavigation() {
    const techsList = document.querySelector(".techs_container ul");
    if (!techsList || (techsList as HTMLElement).dataset.navBound === "1") return;
    (techsList as HTMLElement).dataset.navBound = "1";

    const openLi = (li: HTMLElement) => {
      const href = li.dataset.href;
      if (href) window.open(href, "_blank", "noopener,noreferrer");
    };

    techsList.addEventListener("click", (ev) => {
      const li = (ev.target as HTMLElement).closest<HTMLElement>("li[data-href]");
      if (li) openLi(li);
    });

    techsList.addEventListener("keydown", (ev) => {
      const ke = ev as KeyboardEvent;
      if (ke.key !== "Enter" && ke.key !== " ") return;
      const li = (ke.target as HTMLElement).closest<HTMLElement>("li[data-href]");
      if (li) {
        ev.preventDefault();
        openLi(li);
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    reshuffleHexagons();
    bindPointerMove();
    bindNavigation();
  });
</script>

<style define:vars={{ s, r, mv }}>
  .hidden_text {
    opacity: 0;
  }

  h2:hover .hidden_text {
    opacity: 0.5;
  }

  .techs_container {
    --s: var(--s);
    --r: var(--r);
    --h: 0.5;
    --v: 0.29;
    --hc: calc(clamp(0, var(--h), 0.5) * var(--s));
    --vc: calc(clamp(0, var(--v), 0.5) * var(--s) * var(--r));
    --mv: var(--mv);
    --mh: calc(var(--mv) + (var(--s) - 2 * var(--hc)) / 2);
    --f: calc(2 * var(--s) * var(--r) + 4 * var(--mv) - 2 * var(--vc) - 2px);
  }

  .techs_container ul {
    font-size: 0;
    padding-bottom: calc(var(--s) * var(--r) + var(--mv));
  }

  .techs_container ul::before {
    content: "";
    width: calc(var(--s) / 2 + var(--mh));
    float: left;
    height: 140%;
    shape-outside: repeating-linear-gradient(
      #0000 0 calc(var(--f) - 2px),
      #000 0 var(--f)
    );
  }

  /* Responsive: reduce --s progresivamente + ajusta padding-bottom
     para acomodar más filas cuando viewport se estrecha y los hex
     se apilan más. */
  @media screen and (max-width: 1075px) {
    .techs_container {
      --s: 100px;
    }
  }

  @media screen and (max-width: 780px) {
    .hidden_text {
      opacity: 0.5;
    }
    .techs_container {
      --s: 85px;
    }
    .techs_container ul {
      padding-bottom: 300px;
    }
  }

  @media screen and (max-width: 460px) {
    .techs_container {
      --s: 70px;
    }
    .techs_container ul {
      padding-bottom: 500px;
    }
  }
</style>
