---
import Card from "../Card.astro";
// import Anchor from "../Anchor.astro"; // uncomment when LinkedIn blockquote is re-enabled
import { cases } from "../../data/cases";
import { tFor, type Locale } from "../../i18n";
const t = tFor(Astro);
const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'es';
// Las zonas de magnetismo se calculan en runtime por posición física
// (ver magnetic-cards.ts). Acá ya no se pasan props de zona.
---

<section id="casos">
  <h2 class="Dela"><span class="hidden_text">{t('home.casos.titleHover')}</span> {t('home.casos.title')}</h2>
  <div class="casos-cards">
    {
      cases.map((caseItem) => (
        <div class="casos-slot">
          <Card
            text={caseItem.text[locale]}
            href={caseItem.href}
            company={caseItem.company}
            role={caseItem.role[locale]}
            period={caseItem.period}
            cover={caseItem.cover}
            bgColor={caseItem.bgColor}
            txtColor={caseItem.txtColor}
            tags={caseItem.tags}
          />
        </div>
      ))
    }
  </div>
  <!-- <blockquote class="text_center">
    <Anchor
      href="https://www.linkedin.com/in/vin-dev"
      text={t('home.casos.linkedinAnchor')}
      max_font_size="7rem"
      min_font_size="3rem"
      bgHeight="7.5rem"
      _blank={true}
      svgh={76}
      svgw={75}
      svg={true}
      responsive={true}
    />
  </blockquote> -->
</section>

<script>
  import { initMagneticCards } from "../magnetic-cards";
  document.addEventListener("astro:page-load", initMagneticCards);
</script>

<style>
  .hidden_text {
    opacity: 0;
  }

  h2:hover .hidden_text {
    opacity: 0.5;
  }

  .casos-cards {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: center;
    gap: 32px;
    margin-block: 2rem;
  }

  /*
   * casos-slot reserva el espacio máximo (estado fired) por cada card.
   * El <a class="mg-card"> dentro transiciona height 320 → 400 libremente
   * sin afectar layout: el slot mantiene sus dimensiones fijas + overflow visible.
   * Esto elimina el shift en cascade que afectaba al blockquote inferior.
   */
  .casos-slot {
    width: 280px;
    height: 400px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    flex-shrink: 0;
  }

  #casos blockquote {
    margin-block: 4rem;
    padding-top: 125px;
  }

  @media screen and (max-width: 1075px) {
    .casos-cards {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }
    .casos-slot {
      width: 100%;
      max-width: 320px;
      height: 400px;
    }
  }

  @media screen and (max-width: 780px) {
    .hidden_text {
      opacity: 0.5;
    }
  }
</style>
