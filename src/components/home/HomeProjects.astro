---
import Card from "../Card.astro";
import Anchor from "../Anchor.astro";
import { cases } from "../../data/cases";

function zoneFor(idx: number, total: number) {
  if (total === 1) return { zoneLeft: 220, zoneRight: 220, zoneVert: 120 };
  if (idx === 0) return { zoneLeft: 220, zoneRight: 60, zoneVert: 120 };
  if (idx === total - 1) return { zoneLeft: 60, zoneRight: 220, zoneVert: 120 };
  return { zoneLeft: 20, zoneRight: 20, zoneVert: 240 };
}
---

<section id="casos">
  <h2 class="Dela"><span class="hidden_text">Real</span> CASOS</h2>
  <div class="casos-cards">
    {
      cases.map((caseItem, idx) => {
        const zones = zoneFor(idx, cases.length);
        return (
          <div class="casos-slot">
            <Card
              text={caseItem.text}
              href={caseItem.href}
              company={caseItem.company}
              role={caseItem.role}
              period={caseItem.period}
              cover={caseItem.cover}
              bgColor={caseItem.bgColor}
              txtColor={caseItem.txtColor}
              tags={caseItem.tags}
              zoneLeft={zones.zoneLeft}
              zoneRight={zones.zoneRight}
              zoneVert={zones.zoneVert}
            />
          </div>
        );
      })
    }
  </div>
  <blockquote class="text_center">
    <Anchor
      href="https://www.linkedin.com/in/vin-dev"
      text="Más en LinkedIn "
      max_font_size="7rem"
      min_font_size="3rem"
      bgHeight="7.5rem"
      _blank={true}
      svgh={76}
      svgw={75}
      svg={true}
      responsive={true}
    />
  </blockquote>
</section>

<script>
  import { initMagneticCards } from "../magnetic-cards";
  document.addEventListener("astro:page-load", initMagneticCards);
</script>

<style>
  .hidden_text {
    opacity: 0;
  }

  h2:hover .hidden_text {
    opacity: 0.5;
  }

  .casos-cards {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 32px;
    margin-block: 2rem;
  }

  /*
   * casos-slot reserva el espacio máximo (estado fired) por cada card.
   * El <a class="mg-card"> dentro transiciona height 320 → 400 libremente
   * sin afectar layout: el slot mantiene sus dimensiones fijas + overflow visible.
   * Esto elimina el shift en cascade que afectaba al blockquote inferior.
   */
  .casos-slot {
    width: 280px;
    height: 400px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    flex-shrink: 0;
  }

  #casos blockquote {
    margin-block: 4rem;
    padding-top: 125px;
  }

  @media screen and (max-width: 1075px) {
    .casos-cards {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }
    .casos-slot {
      width: 100%;
      max-width: 320px;
      height: 400px;
    }
  }

  @media screen and (max-width: 780px) {
    .hidden_text {
      opacity: 0.5;
    }
  }
</style>
