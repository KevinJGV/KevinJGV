---
import Anchor from "./Anchor.astro";
import FooterTypewriter from "./footer/FooterTypewriter.astro";
import FooterSocial from "./footer/FooterSocial.astro";
import { tFor } from "../i18n";

interface Props {
  no_top_foot?: boolean;
}

const { no_top_foot = false } = Astro.props;
const t = tFor(Astro);
---

<footer>
  {!no_top_foot && <FooterTypewriter />}
  <section id="mid_foot" class="flex j_sb Poppins-R">
    <FooterSocial />
    <p class="copyright">©<span id="curYear"></span> VIN-DEV</p>
  </section>
  <section id="bot_foot" class="text_center Poppins-R">
    {t('footer.creditsBefore')}<Anchor
      href="https://astro.build/"
      max_font_size="1rem"
      min_font_size="1rem"
      text="Astro"
      bgHeight="1.2rem"
    />{t('footer.creditsAfter')}
  </section>
</footer>

<script>
  document.addEventListener("astro:page-load", () => {
    const curYearEl = document.querySelector("#curYear");
    if (curYearEl) {
      curYearEl.textContent = new Date().getFullYear().toString();
    }
  });
</script>

<style>
  #mid_foot {
    padding: 30px 20px 0;
    border-top: 1px solid var(--border);
  }

  .copyright {
    align-self: flex-end;
    margin-right: 30px;
  }

  #bot_foot {
    color: var(--border);
    margin-bottom: 30px;
  }

  @media screen and (max-width: 600px) {
    #mid_foot {
      flex-direction: column;
    }
  }
</style>
