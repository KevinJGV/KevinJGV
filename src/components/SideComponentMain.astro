---
import esStrings from "../i18n/es";
import enStrings from "../i18n/en";

const nounsEs = esStrings.sidebar.carouselNouns;
const nounsEn = enStrings.sidebar.carouselNouns;
---

<p
  id="carousel"
  class="container Poppins-R text_center"
  data-nouns-es={JSON.stringify(nounsEs)}
  data-nouns-en={JSON.stringify(nounsEn)}
></p>

<script>
    const FADE_MS = 600;
    const CYCLE_MS = 20000;

    // Shuffled queue: cycle through the full set before repeating, and ensure
    // the first word of the next cycle isn't the same as the last of the previous.
    let queue: string[] = [];
    let lastShown: string | null = null;
    let cycleIntervalId: ReturnType<typeof setInterval> | null = null;
    let pendingFadeOut: ((e: TransitionEvent) => void) | null = null;

    function getNouns(carousel: HTMLElement): string[] {
        const onEn = window.location.pathname.startsWith('/en');
        const raw = onEn ? carousel.dataset.nounsEn : carousel.dataset.nounsEs;
        try {
            return raw ? JSON.parse(raw) : [];
        } catch {
            return [];
        }
    }

    function nextOrder(source: string[], avoidFirst: string | null): string[] {
        const arr = source.slice();
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        if (avoidFirst !== null && arr.length > 1 && arr[0] === avoidFirst) {
            const j = 1 + Math.floor(Math.random() * (arr.length - 1));
            [arr[0], arr[j]] = [arr[j], arr[0]];
        }
        return arr;
    }

    function pickNext(source: string[]): string {
        if (source.length === 0) return '';
        if (queue.length === 0) {
            queue = nextOrder(source, lastShown);
        }
        const word = queue.shift()!;
        lastShown = word;
        return word;
    }

    function initCarousel() {
        const carousel = document.querySelector<HTMLElement>("#carousel");
        if (!carousel) return;

        const nouns = getNouns(carousel);
        if (nouns.length === 0) return;

        // Cleanup previous interval + orphan listener (Astro view transitions re-fire astro:page-load)
        if (cycleIntervalId !== null) {
            clearInterval(cycleIntervalId);
            cycleIntervalId = null;
        }
        if (pendingFadeOut !== null) {
            carousel.removeEventListener('transitionend', pendingFadeOut);
            pendingFadeOut = null;
        }

        // Wire FADE_MS to CSS via custom property (JS = single source of truth)
        carousel.style.setProperty('--fade-duration', `${FADE_MS}ms`);

        // Reset shuffled queue + last-shown so re-init starts a fresh cycle
        queue = [];
        lastShown = null;
        carousel.textContent = pickNext(nouns);
        carousel.style.opacity = '0';
        requestAnimationFrame(() => {
            carousel.style.opacity = '1';
        });

        cycleIntervalId = setInterval(() => {
            const currentNouns = getNouns(carousel);
            if (currentNouns.length === 0) return;
            // Clear any orphan listener from a cancelled previous transition
            if (pendingFadeOut !== null) {
                carousel.removeEventListener('transitionend', pendingFadeOut);
                pendingFadeOut = null;
            }
            // Fade out
            carousel.style.opacity = '0';
            pendingFadeOut = (e: TransitionEvent) => {
                if (e.propertyName !== 'opacity') return;
                carousel.removeEventListener('transitionend', pendingFadeOut!);
                pendingFadeOut = null;
                // Swap text while invisible (opacity is literally 0)
                carousel.textContent = pickNext(currentNouns);
                // Force browser to paint a frame with opacity:0 + new text
                // before transitioning opacity back to 1 — eliminates flash
                requestAnimationFrame(() => {
                    carousel.style.opacity = '1';
                });
            };
            carousel.addEventListener('transitionend', pendingFadeOut);
        }, CYCLE_MS);
    }

    document.addEventListener("astro:page-load", initCarousel);
</script>

<style>
    #carousel {
        color: var(--border);
        margin: 18px;
        font-size: 2rem;
        position: relative;
        flex-grow: 2;
        line-height: 0;
        opacity: 1;
        transition: opacity var(--fade-duration, 0.6s) ease-in-out;
    }

    @media screen and (max-height: 600px) {
        p {
            display: none;
        }
    }
</style>
