---
// Vista aislada para iterar el face-puppet: sólo el retrato del hero, centrado,
// con sus mismos estilos. Standalone (sin navbar/sidebar/Layout) → renderiza
// únicamente la imagen.
import "../styles/fonts.css";
import "../styles/utilities.css";
import HeroPhoto from "../components/HeroPhoto.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <title>Face Lab</title>
  </head>
  <body class="noise flex j_c">
    <main class="lab flex j_c">
      <HeroPhoto />
    </main>
  </body>
</html>

<style>
  html, body { margin: 0; min-height: 100dvh; }
  body { background-color: #000; }
  .lab {
    min-height: 100dvh;
    width: 100%;
    align-items: center;
    justify-content: center;
  }
</style>
