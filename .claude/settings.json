{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run start)",
      "Bash(npm run build)",
      "Bash(npm run preview)",
      "Bash(npm run astro)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm ls *)",
      "Bash(npx astro *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(grep *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/astro-check.sh\"",
            "timeout": 60,
            "statusMessage": "Running astro check..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/docs-reminder.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
